#!/usr/bin/env bash
# Launch the dAImon control panel from its venv.
set -uo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  dir="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$dir/$SOURCE" ;; esac
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." >/dev/null 2>&1 && pwd)"
PY="$ROOT/tui/.venv/bin/python"
[ -x "$PY" ] || { echo "TUI venv missing — run 'daimon install' first" >&2; exit 1; }
exec "$PY" "$ROOT/tui/daemonctl.py" "$@"
