# Library files are sourced via a runtime-computed $DAIMON_LIB_DIR path that
# shellcheck cannot resolve statically, so it cannot follow them (SC1091) and
# flags variables that are actually set in those sourced files (SC2034).
disable=SC1091
disable=SC2034
disable=SC2015
# SC2329 (v0.11.0+): "function never invoked" — false-positives on sourced-lib
# functions and on the gh()/tmux() mocks in the bats tests, which are called
# indirectly by the code under test.
disable=SC2329
