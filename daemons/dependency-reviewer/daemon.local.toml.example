# Copy to daemon.local.toml (gitignored) and set values for THIS machine.
[daemon]
working_dir = "~/code/your-repo"   # the repo whose dependency PRs this daemon triages

[inputs]
# GitHub's Dependabot is "app/dependabot"; for Renovate use "app/renovate".
bot_author = "app/dependabot"
base = "main"
