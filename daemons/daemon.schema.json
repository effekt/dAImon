{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dAImon daemon.toml",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "daemon": {
      "type": "object",
      "required": [
        "command",
        "schedule"
      ],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "claude",
            "codex"
          ]
        },
        "model": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ]
        },
        "danger": {
          "type": "boolean"
        },
        "stuck_after": {
          "type": "integer",
          "minimum": 1
        },
        "ready_timeout": {
          "type": "integer",
          "minimum": 1
        },
        "command": {
          "type": "string",
          "pattern": "^/"
        },
        "schedule": {
          "type": "object",
          "oneOf": [
            {
              "required": [
                "interval"
              ],
              "properties": {
                "interval": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            },
            {
              "required": [
                "minutes"
              ],
              "properties": {
                "minutes": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 59
                  }
                }
              },
              "additionalProperties": false
            },
            {
              "required": [
                "daily"
              ],
              "properties": {
                "daily": {
                  "type": "string",
                  "pattern": "^[0-9]{1,2}:[0-9]{2}$"
                },
                "tz": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "source": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "required": [
                  "name"
                ],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "write": {
                    "type": "boolean"
                  }
                }
              }
            ]
          }
        },
        "working_dir": {
          "type": "string"
        },
        "learning": {
          "type": "boolean"
        },
        "mcp": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "codex"
            ]
          }
        },
        "required_inputs": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      }
    },
    "inputs": {
      "type": "object"
    }
  }
}
